{
  "name": "@usethink/shared-frontend",
  "version": "0.1.1",
  "description": "@usethink 前端共享库 — Vue 3 工具函数、组件、Hooks、类型与业务能力",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwdingyu/shared-frontend.git"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/index.d.ts"
    },
    "./utils": {
      "import": "./dist/src/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    },
    "./components": {
      "import": "./dist/src/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/src/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./api": {
      "import": "./dist/src/api/index.js",
      "types": "./dist/api/index.d.ts"
    },
    "./store": {
      "import": "./dist/src/store/index.js",
      "types": "./dist/store/index.d.ts"
    },
    "./types": {
      "import": "./dist/src/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./constants": {
      "import": "./dist/src/constants/index.js",
      "types": "./dist/constants/index.d.ts"
    },
    "./enums": {
      "import": "./dist/src/enums/index.js",
      "types": "./dist/enums/index.d.ts"
    },
    "./styles/*": "./dist/styles/*",
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "prepack": "pnpm run build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "publish": "pnpm exec publish-toolkit publish --package . --registry=https://registry.npmjs.org/ --access=public"
  },
  "keywords": [
    "vue",
    "vue3",
    "frontend",
    "shared-library",
    "usethink",
    "pinia",
    "ant-design-vue"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@ant-design/icons-vue": ">=7.0.0",
    "@microsoft/signalr": ">=8.0.0",
    "@vueuse/core": ">=10.0.0",
    "ant-design-vue": ">=4.0.0",
    "axios": ">=1.0.0",
    "codemirror": ">=5.0.0",
    "cropperjs": ">=1.0.0",
    "dayjs": ">=1.11.0",
    "echarts": ">=5.0.0",
    "lodash-es": ">=4.17.0",
    "mitt": ">=3.0.0",
    "pinia": ">=2.0.0",
    "tinymce": ">=6.0.0",
    "vue": ">=3.0.0",
    "vue-i18n": ">=9.0.0",
    "vue-router": ">=4.0.0",
    "vue-virtual-scroller": ">=2.0.0",
    "xlsx": ">=0.18.0"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "nprogress": "^0.2.0",
    "qs": "^6.15.3",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/ep": "^1.2.4",
    "@types/lodash-es": "~4.17.12",
    "@types/node": "~20.12.4",
    "@types/qs": "^6.15.1",
    "@usethink/publish-toolkit": "~0.1.13",
    "@vitejs/plugin-vue": "~5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "codemirror": "^5.65.21",
    "less": "^4.6.7",
    "typescript": "~5.4.3",
    "vite": "~5.2.8",
    "vite-plugin-dts": "^3.9.1",
    "vue": "~3.5.34",
    "vue-types": "^7.0.0"
  }
}
