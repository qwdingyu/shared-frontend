{
  "name": "@usethink/shared-frontend",
  "version": "0.1.0",
  "description": "@usethink 前端共享库 — Vue 3 工具函数、组件、Hooks、类型与业务能力",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwdingyu/shared-frontend.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs",
      "types": "./dist/utils/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "require": "./dist/components/index.cjs",
      "types": "./dist/components/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs",
      "types": "./dist/hooks/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "require": "./dist/api/index.cjs",
      "types": "./dist/api/index.d.ts"
    },
    "./store": {
      "import": "./dist/store/index.js",
      "require": "./dist/store/index.cjs",
      "types": "./dist/store/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./constants": {
      "import": "./dist/constants/index.js",
      "require": "./dist/constants/index.cjs",
      "types": "./dist/constants/index.d.ts"
    },
    "./enums": {
      "import": "./dist/enums/index.js",
      "require": "./dist/enums/index.cjs",
      "types": "./dist/enums/index.d.ts"
    },
    "./styles/*": "./dist/styles/*",
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "prepack": "pnpm run build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "publish": "pnpm exec publish-toolkit publish --package . --registry=https://registry.npmjs.org/ --access=public"
  },
  "keywords": [
    "vue",
    "vue3",
    "frontend",
    "shared-library",
    "usethink",
    "pinia",
    "ant-design-vue"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@ant-design/icons-vue": ">=7.0.0",
    "@microsoft/signalr": ">=8.0.0",
    "@vueuse/core": ">=10.0.0",
    "ant-design-vue": ">=4.0.0",
    "axios": ">=1.0.0",
    "dayjs": ">=1.11.0",
    "echarts": ">=5.0.0",
    "lodash-es": ">=4.17.0",
    "mitt": ">=3.0.0",
    "pinia": ">=2.0.0",
    "vue": ">=3.0.0",
    "vue-i18n": ">=9.0.0",
    "vue-router": ">=4.0.0"
  },
  "devDependencies": {
    "@types/lodash-es": "~4.17.12",
    "@types/node": "~20.12.4",
    "@usethink/publish-toolkit": "~0.1.13",
    "@vitejs/plugin-vue": "~5.0.4",
    "@vue/tsconfig": "^0.5.1",
    "typescript": "~5.4.3",
    "vite": "~5.2.8",
    "vite-plugin-dts": "^3.9.1",
    "vue": "~3.5.34"
  }
}
