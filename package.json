{
  "name": "@usethink/shared-frontend",
  "version": "0.1.3",
  "description": "@usethink 前端共享库 — Vue 3 工具函数、组件、Hooks、类型与业务能力",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwdingyu/shared-frontend.git"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./utils": "./dist/src/utils/index.js",
    "./components": "./dist/src/components/index.js",
    "./hooks": "./dist/src/hooks/index.js",
    "./api": "./dist/src/api/index.js",
    "./store": "./dist/src/store/index.js",
    "./types": "./dist/src/types/index.js",
    "./constants": "./dist/src/constants/index.js",
    "./enums": "./dist/src/enums/index.js",
    "./styles/*": "./dist/src/styles/*",
    "./*": "./dist/src/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && mkdir -p dist/src/styles && cp src/styles/*.less src/styles/*.css dist/src/styles/",
    "prepack": "pnpm run build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "publish": "pnpm exec publish-toolkit publish --package . --registry=https://registry.npmjs.org/ --access=public"
  },
  "keywords": [
    "vue",
    "vue3",
    "frontend",
    "shared-library",
    "usethink",
    "pinia",
    "ant-design-vue"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["core-js", "esbuild", "vue-demi"]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@ant-design/icons-vue": ">=7.0.0",
    "@antv/x6": "^2.19.2",
    "@antv/x6-plugin-dnd": "^2.1.1",
    "@antv/x6-plugin-export": "^2.1.6",
    "@antv/x6-plugin-keyboard": "^2.2.3",
    "@antv/x6-plugin-selection": "^2.2.2",
    "@antv/x6-plugin-transform": "^2.1.8",
    "@antv/x6-vue-shape": "^2.1.2",
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/ep": "^1.2.4",
    "@iconify/vue": "^4.3.0",
    "@microsoft/signalr": ">=8.0.0",
    "@tinymce/tinymce-vue": "^5.1.1",
    "@vueuse/core": ">=10.0.0",
    "ant-design-vue": ">=4.0.0",
    "axios": ">=1.0.0",
    "codemirror": "^5.65.21",
    "cropperjs": "^1.6.2",
    "dayjs": ">=1.11.0",
    "echarts": ">=5.0.0",
    "lodash-es": ">=4.17.0",
    "mitt": ">=3.0.0",
    "pinia": ">=2.0.0",
    "tinymce": "^6.8.6",
    "vue": ">=3.0.0",
    "vue-i18n": ">=9.0.0",
    "vue-router": ">=4.0.0",
    "vue-virtual-scroller": "^2.0.0",
    "xlsx": "~0.18.5"
  },
  "dependencies": {
    "file-saver": "^2.0.5",
    "nprogress": "^0.2.0",
    "qs": "^6.12.0",
    "sortablejs": "^1.15.0",
    "vue-json-pretty": "^2.6.0",
    "vue-types": "^7.0.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/lodash-es": "~4.17.12",
    "@types/node": "~20.12.4",
    "@types/nprogress": "^0.2.3",
    "@types/qs": "^6.15.1",
    "@types/xlsx": "^0.0.36",
    "@usethink/publish-toolkit": "~0.1.13",
    "@vitejs/plugin-vue": "~5.0.4",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/tsconfig": "^0.5.1",
    "esbuild": "^0.28.1",
    "less": "^4.6.7",
    "pinia": "~2.1.7",
    "typescript": "~5.4.3",
    "vite": "~5.2.8",
    "vite-plugin-dts": "^3.9.1",
    "vue": "~3.5.34",
    "vue-router": "~4.3.3"
  }
}